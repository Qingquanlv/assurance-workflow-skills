{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://aws.local/schemas/risk-advisory-context.schema.json",
  "title": "RiskAdvisoryContext",
  "type": "object",
  "required": [
    "schema_version",
    "change_id",
    "generated_at",
    "aggregation_policy",
    "archive_window",
    "staleness",
    "impact",
    "case_signals",
    "test_health",
    "historical_issues",
    "evidence",
    "degraded",
    "degraded_reasons"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "change_id": { "type": "string" },
    "generated_at": { "type": "string", "format": "date-time" },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "source"],
        "properties": {
          "id": { "type": "string", "pattern": "^EV-" }
        }
      }
    }
  },
  "additionalProperties": true
}
