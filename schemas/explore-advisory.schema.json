{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://aws.local/schemas/explore-advisory.schema.json",
  "title": "ExploreAdvisory",
  "type": "object",
  "required": [
    "schema_version",
    "change_id",
    "context_ref",
    "generated_at",
    "executive_summary",
    "hotspots",
    "watchlist",
    "case_design_guidance",
    "open_questions_for_case_design"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "change_id": { "type": "string" },
    "context_ref": { "type": "string" },
    "hotspots": { "type": "array" },
    "watchlist": { "type": "array" },
    "open_questions_for_case_design": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "question", "maps_to_clarifying_categories"],
        "properties": {
          "id": { "type": "string", "pattern": "^OQ-\\d+$" },
          "question": { "type": "string" },
          "maps_to_clarifying_categories": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "module_confirmation",
                "change_type",
                "test_types",
                "data_needs",
                "success_assertions",
                "exception_scenarios",
                "target_selection_depth",
                "out_of_scope"
              ]
            }
          },
          "options": {
            "type": "array",
            "items": { "type": "string" }
          },
          "answer": {
            "description": "User's answer collected during aws-explore Step 5. null means not yet answered.",
            "oneOf": [
              { "type": "string" },
              { "type": "null" }
            ],
            "default": null
          },
          "answered_via": {
            "description": "Which phase collected the answer. null if not yet answered.",
            "oneOf": [
              { "type": "string", "enum": ["explore"] },
              { "type": "null" }
            ],
            "default": null
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
