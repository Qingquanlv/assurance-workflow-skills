{
  "tier": "local",
  "targets": [
    "api",
    "e2e"
  ],
  "parallel": {
    "api": 4,
    "e2e": 2
  },
  "retry": {
    "api": 0,
    "e2e": 1
  },
  "api": {
    "timeoutSeconds": 30
  },
  "e2e": {
    "browsers": [
      "chromium"
    ],
    "trace": "on-first-retry",
    "screenshot": "only-on-failure",
    "video": "retain-on-failure"
  },
  "healing": {
    "mode": "proposal-only",
    "maxAttempts": 2,
    "allowAssertionChange": false,
    "allowProductCodeChange": false,
    "allowAutoMerge": false
  }
}
