"""
API Tests: Menu Management Module
Change: REQ-004-menu-management
Covers: TC-MENU-API-001 ~ TC-MENU-API-009

Run:
    .venv/bin/python -m pytest tests/api/test_menu_api.py -v

Environment:
    API_BASE_URL    Backend URL  (default: http://localhost:9999)
    ADMIN_USERNAME  Admin account (default: admin)
    ADMIN_PASSWORD  Admin password (default: 123456)
"""

import uuid

import pytest
import requests

from conftest import API_BASE_URL, _api_headers

MENU_CREATE_URL = f"{API_BASE_URL}/api/v1/menu/create"
MENU_LIST_URL = f"{API_BASE_URL}/api/v1/menu/list"
MENU_GET_URL = f"{API_BASE_URL}/api/v1/menu/get"
MENU_UPDATE_URL = f"{API_BASE_URL}/api/v1/menu/update"
MENU_DELETE_URL = f"{API_BASE_URL}/api/v1/menu/delete"

NONEXISTENT_ID = 99999


# ── Fixtures ──────────────────────────────────────────────────────────────────


@pytest.fixture
def test_menu(admin_token: str) -> dict:
    """Creates a test catalog menu, yields {id, name, path}, deletes on teardown."""
    suffix = uuid.uuid4().hex[:8]
    name = f"TC-Menu-{suffix}"
    path = f"/test/menu/{suffix}"

    resp = requests.post(
        MENU_CREATE_URL,
        json={
            "menu_type": "catalog",
            "name": name,
            "path": path,
            "component": "Layout",
            "order": 1,
            "parent_id": 0,
        },
        headers=_api_headers(admin_token),
        timeout=10,
    )
    assert resp.status_code == 200, f"Failed to create test menu: {resp.text}"
    body = resp.json()
    assert body.get("code") == 200, f"Failed to create test menu: {body}"

    menu_id = _get_menu_id_by_name(admin_token, name)
    menu = {"id": menu_id, "name": name, "path": path}

    yield menu

    _delete_menu(admin_token, menu_id)


@pytest.fixture
def test_menu_for_delete(admin_token: str) -> dict:
    """Creates a test leaf menu for deletion test. No teardown (test deletes it)."""
    suffix = uuid.uuid4().hex[:8]
    name = f"TC-MenuDel-{suffix}"
    path = f"/test/del/{suffix}"

    resp = requests.post(
        MENU_CREATE_URL,
        json={
            "menu_type": "catalog",
            "name": name,
            "path": path,
            "component": "Layout",
            "order": 1,
            "parent_id": 0,
        },
        headers=_api_headers(admin_token),
        timeout=10,
    )
    assert resp.status_code == 200, f"Failed to create test menu: {resp.text}"
    body = resp.json()
    assert body.get("code") == 200, f"Failed to create test menu: {body}"

    menu_id = _get_menu_id_by_name(admin_token, name)
    menu = {"id": menu_id, "name": name}

    yield menu

    # Cleanup only if test failed to delete
    try:
        menus = _flatten_menu_tree(
            requests.get(
                MENU_LIST_URL,
                headers=_api_headers(admin_token),
                timeout=10,
            )
            .json()
            .get("data", [])
        )
        if any(m["id"] == menu_id for m in menus):
            _delete_menu(admin_token, menu_id)
    except Exception:
        pass


