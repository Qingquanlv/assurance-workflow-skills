"""
E2E Tests: Menu Management Page
Change: REQ-004-menu-management
Covers: TC-MENU-UI-001 ~ TC-MENU-UI-005

Run:
    uv run pytest tests/e2e/test_menu_management.py -v
    uv run pytest tests/e2e/test_menu_management.py -v --headed  # debug mode

Environment:
    BASE_URL        Frontend URL  (default: http://localhost:3100)
    API_BASE_URL    Backend URL   (default: http://localhost:9999)
    ADMIN_USERNAME  Admin account (default: admin)
    ADMIN_PASSWORD  Admin password (default: 123456)
"""

import sys
import uuid
from pathlib import Path

import pytest
import requests
from playwright.sync_api import Page, expect

_e2e_dir = Path(__file__).resolve().parent
if str(_e2e_dir) not in sys.path:
    sys.path.insert(0, str(_e2e_dir))
from conftest import API_BASE_URL, _api_headers  # noqa: E402

MENU_MGMT_PATH = "/system/menu"
MENU_LIST_URL = f"{API_BASE_URL}/api/v1/menu/list"
MENU_CREATE_URL = f"{API_BASE_URL}/api/v1/menu/create"
MENU_DELETE_URL = f"{API_BASE_URL}/api/v1/menu/delete"


# ── Fixtures ──────────────────────────────────────────────────────────────────


@pytest.fixture
def admin_page_menu(page: Page) -> Page:
    """
    Page fixture with admin auth, navigated to /system/menu.
    Waits for the menu list table to be ready.
    """
    page.goto(f"{BASE_URL}/system/menu", timeout=20000)
    page.wait_for_selector("text=菜单列表", timeout=15000)
    page.wait_for_selector(".n-data-table-tr", timeout=10000)
    return page


@pytest.fixture
def test_menu_a(admin_token: str) -> dict:
    """Creates a test catalog menu for edit test, deletes on teardown."""
    suffix = uuid.uuid4().hex[:8]
    name = f"TC-MenuA-{suffix}"
    path = f"/test/menua/{suffix}"

    resp = requests.post(
        MENU_CREATE_URL,
        json={
            "menu_type": "catalog",
            "name": name,
            "path": path,
            "component": "Layout",
            "order": 1,
            "parent_id": 0,
        },
        headers=_api_headers(admin_token),
        timeout=10,
    )
    _assert_create_ok(resp, "test_menu_a")

    menu_id = _get_menu_id_by_name(admin_token, name)
    menu = {"id": menu_id, "name": name}

    yield menu

    _delete_menu(admin_token, menu_id)


@pytest.fixture
def test_menu_b(admin_token: str) -> dict:
    """Creates a test leaf menu for deletion test. No teardown (test deletes it)."""
    suffix = uuid.uuid4().hex[:8]
    name = f"TC-MenuB-{suffix}"
    path = f"/test/menub/{suffix}"

    resp = requests.post(
        MENU_CREATE_URL,
        json={
            "menu_type": "menu",
            "name": name,
            "path": path,
            "component": "/system/user",
            "order": 1,
            "parent_id": 0,
        },
        headers=_api_headers(admin_token),
        timeout=10,
    )
    _assert_create_ok(resp, "test_menu_b")

    menu_id = _get_menu_id_by_name(admin_token, name)
    menu = {"id": menu_id, "name": name}

    yield menu

    # Cleanup only if test failed to delete
    try:
        menus = _flatten_menu_tree(
            requests.get(
                MENU_LIST_URL,
                headers=_api_headers(admin_token),
                timeout=10,
            )
            .json()
            .get("data", [])
        )
        if any(m["id"] == menu_id for m in menus):
            _delete_menu(admin_token, menu_id)
    except Exception:
        pass


