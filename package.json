{
  "name": "assurance-workflow-skills",
  "version": "0.1.0",
  "description": "AWS — Assurance Workflow Skills CLI",
  "main": "./dist/opencode-plugin.mjs",
  "exports": {
    ".": "./dist/opencode-plugin.mjs",
    "./package.json": "./package.json"
  },
  "files": [
    "dist/opencode-plugin.mjs",
    "dist/opencode-plugin.mjs.map",
    "dist/cli.js",
    "dist/**/*.js",
    "dist/**/*.js.map",
    ".opencode/skills",
    ".opencode/opencode-skills.json",
    ".opencode/hybrid-phase-map.yaml",
    ".opencode/agents",
    ".opencode/commands",
    ".opencode/plugins/aws.mjs"
  ],
  "bin": {
    "aws": "./dist/cli.js"
  },
  "scripts": {
    "build": "node scripts/sync-opencode-skills.mjs && tsc && node scripts/build-opencode-plugin.mjs",
    "build:watch": "tsc --watch",
    "start": "node dist/cli.js",
    "dev": "ts-node src/cli.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "tsc --noEmit",
    "validate:phase-map": "node scripts/validate-phase-map.mjs",
    "validate:commands": "node scripts/validate-opencode-command.mjs",
    "generate:commands": "node scripts/generate-opencode-commands.mjs"
  },
  "dependencies": {
    "@types/xml2js": "^0.4.14",
    "chalk": "^4.1.2",
    "commander": "^12.1.0",
    "inquirer": "^8.2.6",
    "js-yaml": "^4.1.0",
    "jsonc-parser": "^3.3.1",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/inquirer": "^8.2.10",
    "@types/jest": "^29.5.12",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.14.0",
    "jest": "^29.7.0",
    "esbuild": "^0.25.0",
    "ts-jest": "^29.1.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
